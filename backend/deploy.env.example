# VPS deploy config — copy to deploy.env (never commit deploy.env)
# Used by: scripts/deploy_from_windows.ps1
# Also used by: any one-off backend/scripts/*.py ops script via scripts/_vps_env.py
#   (get_vps_credentials() loads this file and requires VPS_HOST/VPS_PASSWORD —
#   never hardcode VPS credentials directly in a script)
# Pipeline secrets stay in .env (SUPABASE_* etc.)

# A template carries NAMES, never values — the real host/credentials live only in
# deploy.env (gitignored). Publishing the host alongside the login is handing over
# both the address and the key.
# Prefer an SSH key + a non-root deploy user over VPS_PASSWORD.
VPS_HOST=203.0.113.10
VPS_PORT=22
VPS_USER=deploy
VPS_PASSWORD=

# Remote install path
VPS_DEPLOY_ROOT=/opt/vibepin

# Human-readable note for the team (not used by scripts)
VPS_LABEL=Alibaba Cloud Ubuntu 24.04 Ubuntu-gxlv
