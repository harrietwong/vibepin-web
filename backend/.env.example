# Copy to `.env`. Never commit real secrets.
# Cloud worker: set these as platform secrets (see CLOUD_DEPLOY_CHECKLIST.md).

# Supabase (required for pipeline worker)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# 直连 PostgreSQL（迁移 / 批量写入用，注意密码特殊字符需 URL 编码）
# 例：密码 [abc!123] → %5Babc%21123%5D
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# LinAPI (OpenAI-compatible gateway — do NOT set bases to api.openai.com)
LINAPI_KEY=
LINAPI_BASE_URL=https://api.linapi.net/v1
LINAPI_ANALYSIS_MODEL=gemini-2.5-flash
LINAPI_COPY_MODEL=gemini-2.5-flash
LINAPI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Vision-to-Prompt enhancer model (must support vision + JSON output).
# Leave blank to disable the enhancer and fall back to the base prompt template.
OPENAI_PROMPT_ENHANCER_MODEL=
LINAPI_IMAGE_MODEL_FALLBACK=gemini-3.1-flash-image-preview-2K,gemini-3-pro-image-preview,gemini-3-pro-image-preview-2K
LINAPI_IMAGE_ASPECT_RATIO=3:4
LINAPI_IMAGE_SIZE=1K

# Pinterest OAuth app + Trends API
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_TRENDS_ACCESS_TOKEN=
PINTEREST_TRENDS_VIBEPIN_USER_ID=
PINTEREST_TOKEN_ENC_KEY=
ENABLE_PINTEREST_TRENDS_V5=true
ENABLE_PINTEREST_TRENDS_L1=false
ENABLE_PINTEREST_RESOURCE_L2=false
ENABLE_PINTEREST_TRENDS_EXPERIMENTAL_FALLBACK=true
ENABLE_TYPEAHEAD_L3=true
ALLOW_DEGRADED_L3_WRITES=false
PINTEREST_REDIRECT_URI=http://localhost:8000/api/auth/pinterest/callback
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/auth/instagram/callback
REDIS_URL=redis://localhost:6379
APP_SECRET_KEY=change-me
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
