# Copy to `.env.local`. Never commit real secrets. (.env* is gitignored.)

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Backend (FastAPI) base URL used by legacy /settings calls and /api/generate.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Paddle Billing (checkout on /pricing) ─────────────────────────────────────
# Server-side only. Paddle API secret for backend/webhook calls — NEVER prefix
# with NEXT_PUBLIC_ and never expose to the browser.
PADDLE_API_KEY=
# Which Paddle environment to target. Must be exactly "production" or "sandbox"
# (no default — the client throws if unset/invalid and falls back to static prices).
NEXT_PUBLIC_PADDLE_ENV=production
# Paddle client-side token (live_… in production, test_… in sandbox). Safe to
# expose to the browser; used by @paddle/paddle-js for PricePreview + Checkout.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Notification-destination signing secret (pdl_ntfset_…) used to VERIFY inbound
# webhook signatures — this is NOT the API key. Server-side only; the webhook
# route returns 500 (not 2xx) when it is unset so real events are never dropped.
PADDLE_WEBHOOK_SECRET=

# ── Creem Billing (merchant of record after Paddle) ───────────────────────────
# Billing mode — the production release guard. One of: disabled | test | live.
#   disabled (default when unset) → checkout is off; paid buttons show "coming
#            soon" (the checkout endpoint returns 503 billing_disabled).
#   test     → sandbox billing (test-api.creem.io). Allowed in preview/local ONLY;
#            a production deploy REFUSES this (and refuses a creem_test_ key) —
#            predeploy-guard fails and the checkout route 500s.
#   live     → real billing (api.creem.io). Requires a non-test CREEM_API_KEY, all
#            six CREEM_PRODUCT_* ids, and CREEM_WEBHOOK_SECRET.
CREEM_MODE=disabled
# Server-side only. Creem BILLING API secret (checkout/portal). NEVER prefix with
# NEXT_PUBLIC_. Under CREEM_MODE=disabled (review/Demo) leave this EMPTY — checkout
# stays "Coming soon". The predeploy guard only requires a real (non-test) value
# when CREEM_MODE=live. Do NOT put a test key here for production; use the separate
# moderation key below for generation during the Demo phase.
CREEM_API_KEY=
# Server-side only. DEDICATED key for AI prompt moderation (POST /v1/moderation/
# prompt) that gates image generation in /api/generate — SEPARATE from the billing
# key so the Demo phase can moderate with a TEST key while billing stays disabled
# with an empty CREEM_API_KEY. Base URL chosen by KEY PREFIX (creem_test_ →
# test-api.creem.io; else api.creem.io). If this is unset, moderation falls back to
# CREEM_API_KEY (single-live-key phase). Missing BOTH → generation is BLOCKED
# (fail-closed, 503 moderation_unavailable). Never prefix with NEXT_PUBLIC_.
CREEM_MODERATION_API_KEY=
# Webhook signing secret (Developers > Webhook signing secret). Verifies the
# `creem-signature` HMAC on POST /api/webhooks/creem. Server-side only; the route
# returns 500 (not 2xx) when unset so real events are never dropped.
CREEM_WEBHOOK_SECRET=
# Creem product ids (test-mode prod_… ) → VibePin plan/interval map. Server-only.
CREEM_PRODUCT_STARTER_MONTHLY=
CREEM_PRODUCT_STARTER_YEARLY=
CREEM_PRODUCT_PRO_MONTHLY=
CREEM_PRODUCT_PRO_YEARLY=
CREEM_PRODUCT_BUSINESS_MONTHLY=
CREEM_PRODUCT_BUSINESS_YEARLY=

# ── Pinterest OAuth (server-side only — never exposed to the client) ──────────
# Register the redirect URI EXACTLY as below in the Pinterest app settings.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/api/auth/pinterest/callback

# AES-256-GCM key used to encrypt Pinterest tokens at rest and seal the OAuth
# state cookie. Must decode to exactly 32 bytes (base64 or hex). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PINTEREST_TOKEN_ENC_KEY=

# NOTE: the legacy global `pinterest_access_token` in api/.env is intentionally
# NOT used by the user OAuth flow.

# ── Pinterest Sandbox demo mode (server-side only — never exposed to client) ──
# For demoing the full API integration (Create Pin) while production Standard
# access is still pending approval. These MUST live in web/.env.local — the
# Next.js API routes under web/src/app/api/pinterest/* read them at runtime.
# Do NOT prefix with NEXT_PUBLIC_. The token is read only server-side and is
# never logged or returned to the browser.
#
# Set PINTEREST_API_ENV=sandbox to route Pinterest API calls to the sandbox host
# and allow a sandbox Create Pin. Leave unset (or =production) for normal prod —
# production still requires real Standard access and is never bypassed.
PINTEREST_API_ENV=sandbox
PINTEREST_SANDBOX_BASE_URL=https://api-sandbox.pinterest.com/v5
PINTEREST_SANDBOX_ACCESS_TOKEN=
# Lowercase `pinterest_sandbox_access_token` is also supported for local
# compatibility (either variable name is read).

# ── Image generation (forwarded to backend/generator.py) ──────────────────────
LINAPI_KEY=
LINAPI_BASE_URL=https://api.linapi.net/v1
LINAPI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Per-provider image models for the Create Pins model switch (GPT Image / Gemini Image).
# gpt_image  → LINAPI_GPT_IMAGE_MODEL   (defaults to gpt-image-2)
# gemini_image → LINAPI_GEMINI_IMAGE_MODEL (required for the Gemini path; falls back to
#   LINAPI_IMAGE_MODEL only if that is itself a Gemini image model, else a clear
#   "Gemini image model is not configured." error is returned).
LINAPI_GPT_IMAGE_MODEL=gpt-image-2
LINAPI_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
OPENAI_PROMPT_ENHANCER_MODEL=

# ── Social publishing provider (server-side only — never exposed to client) ───
# These are read by the Next.js API routes under web/src/app/api/social/*.
# IMPORTANT: they MUST live in web/.env.local (this app's root). The Next.js
# server does NOT read api/.env — that file is for the separate FastAPI service.
#
# Which vendor brokers multi-platform connect + publish. Defaults to "mock"
# (no credentials, no live calls) when unset. Set to "zernio" to go live.
SOCIAL_PUBLISHING_PROVIDER=mock
# Zernio API credentials. Server-only. Do NOT prefix with NEXT_PUBLIC_ and never
# log the key. Get one at https://zernio.com (format: sk_ + 64 hex chars).
ZERNIO_API_KEY=
# Optional — defaults to https://zernio.com/api/v1 when unset.
ZERNIO_BASE_URL=https://zernio.com/api/v1
# Optional — scopes connect/accounts to a single Zernio profile if you use them.
ZERNIO_PROFILE_ID=

# Multi-account entry ("Add another Pinterest account" / "Add another account").
# OFF by default. Must be NEXT_PUBLIC_ to be readable in the client Settings panels.
# When true, connected-and-healthy accounts show a secondary "Add another …" button.
NEXT_PUBLIC_ENABLE_MULTI_SOCIAL_ACCOUNTS=false

# Ask VibePin (bottom-right AI page assistant on Create Pins). OFF by default —
# it is not part of the Customer Support MVP. Set to "true" locally to test the
# assistant widget; leave false/unset in production.
NEXT_PUBLIC_ENABLE_ASK_VIBEPIN=false

# ── Customer Support MVP (ticket system) ───────────────────────────────────────
# Admin console roles — comma-separated emails. SUPER_ADMIN_EMAILS already gates
# /admin/*; SUPPORT_ADMIN_EMAILS additionally grants the lower "support" tier
# (can triage/reply to tickets in /admin/support without full admin access).
SUPER_ADMIN_EMAILS=
SUPPORT_ADMIN_EMAILS=
# Where "new ticket" admin-notification emails are sent. Leave blank to skip
# that notification (user confirmation + admin reply emails still send).
SUPPORT_NOTIFICATION_EMAIL=
# "From" address used for all support emails.
SUPPORT_EMAIL_FROM=VibePin Support <support@vibepin.co>
# Resend API key. When unset, support emails are logged to the server console
# instead of sent (safe local-dev fallback) — see web/src/lib/support/email.ts.
RESEND_API_KEY=
# Base URL used to build links inside support emails (admin ticket URL, user
# ticket URL). Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional. Chat model used by the support AI (First Responder + admin-side
# translation/summary/suggest-reply) via LINAPI — see LINAPI_KEY/LINAPI_BASE_URL
# above. Defaults to "gemini-2.5-flash" when unset (gpt-4o-mini has NO channel
# on our LINAPI account — 503 model_not_found). When LINAPI_KEY is unset, all
# support AI is skipped silently — tickets still work normally either way.
SUPPORT_AI_MODEL=gemini-2.5-flash

# ── Shopify integration (server-side only — never exposed to the client) ──────
# OAuth app credentials from the Shopify Partner dashboard. Register the redirect
# URI EXACTLY as SHOPIFY_REDIRECT_URI below in the app's OAuth settings.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/integrations/shopify/callback
# Admin API version used for all GraphQL/REST calls. Keep pinned.
SHOPIFY_API_VERSION=2026-07
# AES-256-GCM key to encrypt Shopify tokens at rest and seal the OAuth state
# cookie. Must decode to exactly 32 bytes (base64 or hex). Independent of the
# Pinterest key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SHOPIFY_TOKEN_ENCRYPTION_KEY=
# Requested OAuth scopes (comma-separated). Intersected with the read-only safe
# default; anything else is dropped. Leave as read_products.
SHOPIFY_SCOPES=read_products
# Public app origin used to build the webhook callback URL (…/api/integrations/
# shopify/webhooks). In production set to https://vibepin.co.
SHOPIFY_APP_URL=http://localhost:3000

# Per-plan product sync caps (entitlements). Optional overrides — defaults are
# free 0 / starter 100 / pro 500 / business 1000 when unset.
SHOPIFY_PRODUCT_LIMIT_FREE=0
SHOPIFY_PRODUCT_LIMIT_STARTER=100
SHOPIFY_PRODUCT_LIMIT_PRO=500
SHOPIFY_PRODUCT_LIMIT_BUSINESS=1000

# UI gray-launch flag for the Shopify integration surface (Settings tab, picker
# tab, StudioBoard entry). Must be NEXT_PUBLIC_ to be readable client-side.
# OFF by default; routes (launch/callback/webhooks) are not gated by this.
NEXT_PUBLIC_SHOPIFY_INTEGRATION=false

# E2E test mode — bypasses auth middleware for Playwright. MUST be false in
# production; only ever set to true in a local/CI test environment.
E2E_TEST_MODE=false

# ── Generation / moderation test seams (TEST-ONLY) ────────────────────────────
# Enables the mock image provider AND unlocks the moderation mock seam below.
# MUST be false/unset in production.
ALLOW_GENERATION_MOCK_PROVIDER=false
# Forces a deterministic moderation decision for tests WITHOUT any live Creem
# call. One of: allow | flag | deny | timeout | error | malformed | non2xx |
# unknown | missing_key.
# !!! IGNORED unless ALLOW_GENERATION_MOCK_PROVIDER=true. NEVER set this in
# production — it would let prompts skip real screening.
MODERATION_MOCK_DECISION=
